# ===========================================================================
#  Mohajer — bot.env  (copy to the server as the file referenced by DPBOT_ENV,
#  default /opt/mohajer/bot.env, then `chmod 600`). NEVER commit the real file.
# ===========================================================================

# ---- Telegram ----
# Token from @BotFather.
BOT_TOKEN=123456789:PUT-YOUR-BOTFATHER-TOKEN-HERE
# Numeric admin user IDs (comma separated). The bot answers ONLY these IDs.
# Get yours from @userinfobot. If left empty, the FIRST person to /start is
# captured as admin (single-admin bootstrap) — set it explicitly in production.
ADMIN_IDS=585819227

# ---- Paths / binaries ----
XRAY_BIN=/usr/local/bin/xray
XRAY_API=127.0.0.1:10085          # xray gRPC api inbound (dokodemo) host:port
DB=/opt/mohajer/dpbot.db          # sqlite db (created on first run)
SUB_DIR=/opt/mohajer/sub          # where sub-* files are written (served by sub-server)
POLL_SECONDS=30                   # enforcer poll interval (quota/expiry/resync)

# ---- Public surface (Cloudflare) ----
DOMAIN=cdn.example.ir                       # the SNI/Host clients send (your CF-proxied hostname)
SUB_BASE_URL=https://cdn.example.ir         # base for the sub link shown to users

# ---- Clean Cloudflare edge IPs ----
# Default IPs the links point at. Editable live from the bot's "🌐 آی‌پی‌های تمیز"
# panel (stored in meta.clean_ips, which overrides this). Round-robined across the
# config slots of every link. Pick IPs that are fast/clean from your users' ISPs.
IPS=104.16.96.1,104.21.96.1,104.19.96.1

# ---- Endpoints (the heart of the config) ----
# JSON array. One object per xray inbound. For each endpoint the bot mints one
# config per port: each TLS port -> a TLS config, each no-TLS port -> a plain config.
# Fields:
#   proto : vless | vmess | trojan
#   net   : ws | xhttp
#   tag   : MUST match the inbound `tag` in xray config.json (used by adu/rmu/stats)
#   port  : the inbound's local port (xray listens on 127.0.0.1:port; tunnel routes to it)
#   path  : WS/XHTTP path (must match xray inbound AND the cloudflared ingress rule)
#   label : human label shown in the client (… · <ip> is appended)
#   tls_ports   : Cloudflare HTTPS ports to emit TLS configs on   (443,2053,2083,2087,2096,8443)
#   notls_ports : Cloudflare HTTP  ports to emit no-TLS configs on (80,8080,8880,2052,2082,2086,2095)
#                 NOTE: no-TLS only works if "Always Use HTTPS" is OFF in the CF zone.
ENDPOINTS=[{"proto":"vless","net":"ws","tag":"vless-ws","port":10000,"path":"/1afb5cae5563","label":"VLESS-WS","tls_ports":[443,2053],"notls_ports":[80,8080]},{"proto":"vmess","net":"ws","tag":"vmess-ws","port":10003,"path":"/vmd32dedfa","label":"VMESS-WS","tls_ports":[8443],"notls_ports":[80]},{"proto":"trojan","net":"ws","tag":"trojan-ws","port":10002,"path":"/tr4b0be2a3","label":"TROJAN-WS","tls_ports":[2087],"notls_ports":[8880]},{"proto":"vless","net":"xhttp","tag":"vless-xh","port":10001,"path":"/xh38900ed9","label":"VLESS-XHTTP","tls_ports":[443],"notls_ports":[]}]
